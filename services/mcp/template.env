STACK_NAME=${STACK_NAME}
MONITORING_DOMAIN=${MONITORING_DOMAIN}
PUBLIC_NETWORK=${PUBLIC_NETWORK}
MONITORED_NETWORK=${MONITORED_NETWORK}

# MCP Aggregator configuration
MCP_AGGREGATOR_IMAGE=${MCP_AGGREGATOR_IMAGE}
MCP_PORT=${MCP_PORT}
MCP_LOG_LEVEL=${MCP_LOG_LEVEL}
MCP_REPLICAS=${MCP_REPLICAS}

# Tempo MCP backend
MCP_TEMPO_ENABLED=${MCP_TEMPO_ENABLED}
MCP_TEMPO_URL=${MCP_TEMPO_URL}

# Prometheus MCP backend
MCP_PROMETHEUS_ENABLED=${MCP_PROMETHEUS_ENABLED}
MCP_PROMETHEUS_URL=${MCP_PROMETHEUS_URL}
MCP_PROMETHEUS_BACKEND_URL=${MCP_PROMETHEUS_BACKEND_URL}
MCP_PROMETHEUS_REPLICAS=${MCP_PROMETHEUS_REPLICAS}

# Portainer MCP backend (stdio, embedded in aggregator)
# Token is auto-generated at startup from Portainer admin credentials
MCP_PORTAINER_ENABLED=${MCP_PORTAINER_ENABLED}
MCP_PORTAINER_SERVER=${MCP_PORTAINER_SERVER}
PORTAINER_USER=${PORTAINER_USER}
PORTAINER_PASSWORD=${PORTAINER_PASSWORD}
MCP_PORTAINER_READ_ONLY=${MCP_PORTAINER_READ_ONLY}

# RabbitMQ MCP backend (stdio, embedded in aggregator)
# Connection is established at runtime via rabbitmq_broker_initialize_connection tool
# Credentials are injected into server instructions so the AI auto-connects
MCP_RABBITMQ_ENABLED=${MCP_RABBITMQ_ENABLED}
RABBIT_HOST=${RABBIT_HOST}
RABBIT_USER=${RABBIT_USER}
RABBIT_PASSWORD=${RABBIT_PASSWORD}
RABBIT_PORT=${RABBIT_PORT}
RABBIT_SECURE=${RABBIT_SECURE}

# Postgres MCP backend (stdio, embedded in aggregator, restricted/read-only mode)
# Uses the read-only Postgres user for double safety
MCP_POSTGRES_ENABLED=${MCP_POSTGRES_ENABLED}
POSTGRES_HOST=${POSTGRES_HOST}
POSTGRES_PORT=${POSTGRES_PORT}
POSTGRES_DB=${POSTGRES_DB}
POSTGRES_READONLY_USER=${POSTGRES_READONLY_USER}
POSTGRES_READONLY_PASSWORD=${POSTGRES_READONLY_PASSWORD}

# Grafana MCP backend (sidecar: grafana/mcp-grafana in streamable-http mode)
# Uses SERVICES_USER/SERVICES_PASSWORD for Grafana basic auth (no service account token needed)
MCP_GRAFANA_ENABLED=${MCP_GRAFANA_ENABLED}
MCP_GRAFANA_URL=${MCP_GRAFANA_URL}
MCP_GRAFANA_BACKEND_URL=${MCP_GRAFANA_BACKEND_URL}
MCP_GRAFANA_IMAGE=${MCP_GRAFANA_IMAGE}
MCP_GRAFANA_REPLICAS=${MCP_GRAFANA_REPLICAS}
SERVICES_USER=${SERVICES_USER}
SERVICES_PASSWORD=${SERVICES_PASSWORD}
