version: "3.7"

services:
  mcp-aggregator:
    image: local/mcp-aggregator:latest
    init: true
{%- raw %}
    hostname: "mcp-aggregator-{{.Node.Hostname}}-{{.Task.Slot}}"
{%- endraw %}
    environment:
      - MCP_TEMPO_ENABLED=${MCP_TEMPO_ENABLED}
      - MCP_TEMPO_URL=${MCP_TEMPO_URL}
      - MCP_GRAFANA_ENABLED=${MCP_GRAFANA_ENABLED}
      - MCP_GRAFANA_URL=${MCP_GRAFANA_URL}
      - MCP_PROMETHEUS_ENABLED=${MCP_PROMETHEUS_ENABLED}
      - MCP_PROMETHEUS_URL=${MCP_PROMETHEUS_URL}
      - MCP_PORTAINER_ENABLED=${MCP_PORTAINER_ENABLED}
      - MCP_PORTAINER_SERVER=${MCP_PORTAINER_SERVER}
      - PORTAINER_USER=${PORTAINER_USER}
      - PORTAINER_PASSWORD=${PORTAINER_PASSWORD}
      - MCP_PORTAINER_READ_ONLY=${MCP_PORTAINER_READ_ONLY}
      - MCP_RABBITMQ_ENABLED=${MCP_RABBITMQ_ENABLED}
      - RABBIT_HOST=${RABBIT_HOST}
      - RABBIT_USER=${RABBIT_USER}
      - RABBIT_PASSWORD=${RABBIT_PASSWORD}
      - RABBIT_PORT=${RABBIT_PORT}
      - RABBIT_SECURE=${RABBIT_SECURE}
      - MCP_POSTGRES_ENABLED=${MCP_POSTGRES_ENABLED}
      - POSTGRES_HOST=${POSTGRES_HOST}
      - POSTGRES_PORT=${POSTGRES_PORT}
      - POSTGRES_DB=${POSTGRES_DB}
      - POSTGRES_READONLY_USER=${POSTGRES_READONLY_USER}
      - POSTGRES_READONLY_PASSWORD=${POSTGRES_READONLY_PASSWORD}
      - MONITORING_DOMAIN=${MONITORING_DOMAIN}
      - MCP_HOST=0.0.0.0
      - MCP_PORT=${MCP_PORT}
      - MCP_LOG_LEVEL=${MCP_LOG_LEVEL}
    networks:
      - monitored
      - public
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.labels.ops==true
      resources:
        limits:
          cpus: "1.0"
          memory: 1G
        reservations:
          cpus: "0.1"
          memory: 256M
      update_config:
        parallelism: 1
        order: start-first
        failure_action: continue
        delay: 10s
      labels:
        - traefik.enable=true
        - traefik.swarm.network=${PUBLIC_NETWORK}
        # MCP aggregator service
        - traefik.http.services.mcp_aggregator.loadbalancer.server.port=${MCP_PORT}
        - traefik.http.routers.mcp_aggregator.rule=Host(`${MONITORING_DOMAIN}`) && PathPrefix(`/mcp`)
        - traefik.http.routers.mcp_aggregator.priority=10
        - traefik.http.routers.mcp_aggregator.entrypoints=https
        - traefik.http.routers.mcp_aggregator.tls=true
        # Security: IP allowlist + BasicAuth + gzip
        - traefik.http.routers.mcp_aggregator.middlewares=ops_whitelist_ips@swarm, ops_auth@swarm, ops_gzip@swarm

  # ---- Prometheus MCP sidecar (pab1it0/prometheus-mcp-server) ----
  mcp-prometheus:
    image: ghcr.io/pab1it0/prometheus-mcp-server:1.5.3
    init: true
{%- raw %}
    hostname: "mcp-prometheus-{{.Node.Hostname}}-{{.Task.Slot}}"
{%- endraw %}
    environment:
      - PROMETHEUS_URL=${MCP_PROMETHEUS_BACKEND_URL}
      - PROMETHEUS_MCP_SERVER_TRANSPORT=http
      - PROMETHEUS_MCP_BIND_HOST=0.0.0.0
      - PROMETHEUS_MCP_BIND_PORT=8080
    networks:
      - monitored
    deploy:
      replicas: ${MCP_PROMETHEUS_REPLICAS}
      placement:
        constraints:
          - node.labels.ops==true
      resources:
        limits:
          cpus: "0.5"
          memory: 512M
        reservations:
          cpus: "0.1"
          memory: 128M
      update_config:
        parallelism: 1
        order: start-first
        failure_action: continue
        delay: 10s
      labels:
        - prometheus-job=mcp_prometheus
        - prometheus-port=8080
    healthcheck:
      test: ["CMD-SHELL", "pgrep -f prometheus-mcp-server >/dev/null 2>&1 || exit 1"]
      interval: 30s
      timeout: 5s
      start_period: 10s
      retries: 3

  # ---- Grafana MCP sidecar (grafana/mcp-grafana) ----
  mcp-grafana:
    image: mcp/grafana
    init: true
{%- raw %}
    hostname: "mcp-grafana-{{.Node.Hostname}}-{{.Task.Slot}}"
{%- endraw %}
    environment:
      - GRAFANA_URL=${MCP_GRAFANA_BACKEND_URL}
      - GRAFANA_USERNAME=${SERVICES_USER}
      - GRAFANA_PASSWORD=${SERVICES_PASSWORD}
    networks:
      - monitored
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.labels.ops==true
      resources:
        limits:
          cpus: "0.5"
          memory: 512M
        reservations:
          cpus: "0.1"
          memory: 128M
      update_config:
        parallelism: 1
        order: start-first
        failure_action: continue
        delay: 10s
      labels:
        - prometheus-job=mcp_grafana
        - prometheus-port=8000
    command:
      - "-t"
      - "streamable-http"
      - "--address"
      - "0.0.0.0:8000"
      - "--disable-write"
    healthcheck:
      disable: true

networks:
  monitored:
    name: ${MONITORED_NETWORK}
    external: true
  public:
    external: true
    name: ${PUBLIC_NETWORK}
